# 🌐 Variables de entorno - Backend
# Copia este archivo a .env y completa con tus valores reales

# 🔧 SERVIDOR
PORT=3000
NODE_ENV=development

# 🗄️ BASE DE DATOS SUPABASE
# Obtener de: https://app.supabase.com → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# 🔐 AUTENTICACIÓN JWT
# Generar con: openssl rand -base64 32
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui_minimo_32_caracteres
JWT_EXPIRY=7d

# 💰 CONFIGURACIÓN DE NEGOCIO
IVA_RATE=0.16
MAX_DISCOUNT_PERCENT=10

# 📧 SMTP (Opcional - para envío de emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_aqui
SMTP_FROM=tu_email@gmail.com

# 🔍 LOGGING
LOG_LEVEL=debug

# 📊 CORS (Específicar origen del Frontend)
CORS_ORIGIN=http://localhost:5173

# 🌍 ENTORNO (development, staging, production)
ENVIRONMENT=development
